# Copy this file to ".env" and fill in real values. Never commit ".env".

# ---- Plaid ----
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
# One of: sandbox | development | production
PLAID_ENV=sandbox

# ---- Anthropic ----
# Get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model for the chat sidebar: claude-sonnet-4-6 (cheaper/faster) or claude-opus-4-7
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- App ----
# Used by the PII scrubber to redact your name from chat context.
# Comma-separated; e.g. "Jane Doe,Jane,J. Doe"
USER_NAME=

# Path to the local SQLite database file.
DB_PATH=finance.db

# Set to "1" to seed the DB with mock data on first run (no Plaid needed).
USE_MOCK_DATA=1
