# Copy this file to ".env" and fill in real values. Never commit ".env".

# ---- Plaid ----
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
# One of: sandbox | development | production
PLAID_ENV=sandbox

# ---- Anthropic ----
# Get this from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model for the chat sidebar: claude-sonnet-4-6 (cheaper/faster) or claude-opus-4-7
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- App ----
# Path to the local SQLite database file.
DB_PATH=finance.db

# ---- Daily text report (Phase 7) ----
# Channel: email_sms | twilio | ntfy | console
NOTIFY_CHANNEL=console

# email_sms (free): SMTP account -> your carrier's email-to-SMS gateway.
# Gmail needs an App Password (not your login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Full gateway address: <number>@<carrier gateway>
#   Verizon vtext.com · AT&T txt.att.net · T-Mobile tmomail.net
SMS_TO_EMAIL=

# twilio (paid): https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_TO=

# ntfy (free push, easiest): pick a hard-to-guess topic, subscribe in the ntfy app
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# Set to "1" to seed the DB with mock data on first run (no Plaid needed).
USE_MOCK_DATA=1
